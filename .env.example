# Copy to .env for local dev — never commit .env

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/btl_dev
DB_USERNAME=postgres
DB_PASSWORD=your-password-here

# AviationStack (free tier: 100 requests/month)
AVIATIONSTACK_API_KEY=your-aviationstack-key

# Notifications
# Set SMS_ENABLED=true in production to enable outbound Twilio SMS/WhatsApp
SMS_ENABLED=false

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SendGrid (email)
SENDGRID_API_KEY=SG.xxxxxx
SENDGRID_FROM_EMAIL=info@theevicta.com

# Admin — JWT auth (POST /api/v1/admin/login returns a Bearer token)
# JWT_SECRET must be ≥32 characters. Generate: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-32-plus-char-string

# Admin users — store bcrypt hashes of passwords (never plaintext)
# Generate a hash: htpasswd -bnBC 10 "" yourpassword | tr -d ':\n'
ADMIN_1_USERNAME=joba
ADMIN_1_PASSWORD_HASH=$2y$10$REPLACE_WITH_REAL_BCRYPT_HASH
ADMIN_2_USERNAME=moses
ADMIN_2_PASSWORD_HASH=$2y$10$REPLACE_WITH_REAL_BCRYPT_HASH

# App
FRONTEND_BASE_URL=https://yourapp.vercel.app
SPRING_PROFILES_ACTIVE=prod
